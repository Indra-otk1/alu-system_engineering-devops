#!/usr/bin/env bash
# 0-transfer_file
# Transfers a file from client to a server using scp
# Usage: 0-transfer_file PATH_TO_FILE IP USERNAME PATH_TO_SSH_KEY

if [ "$#" -lt 4 ]; then
    echo "Usage: 0-transfer_file PATH_TO_FILE IP USERNAME PATH_TO_SSH_KEY"
    exit 1
fi

FILE_PATH="$1"
SERVER_IP="$2"
USERNAME="$3"
SSH_KEY="$4"

# Perform the transfer; disable strict host key checking
scp -i "$SSH_KEY" -o StrictHostKeyChecking=no "${FILE_PATH}" "${USERNAME}@${SERVER_IP}:~/"

exit $?
