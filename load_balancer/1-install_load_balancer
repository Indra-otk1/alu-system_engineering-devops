#!/usr/bin/env bash
# Install and configure HAProxy

apt-get update -y
apt-get install -y haproxy

# Enable HAProxy
sed -i 's/ENABLED=0/ENABLED=1/' /etc/default/haproxy

# Configure HAProxy
cat <<EOF >> /etc/haproxy/haproxy.cfg

frontend http_front
    bind *:80
    default_backend web_back

backend web_back
    balance roundrobin
    server web-01 172.31.24.101:80 check
    server web-02 172.31.20.233:80 check
EOF

service haproxy restart
